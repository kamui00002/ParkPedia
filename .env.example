# Firebase Configuration
# Firebase Console > プロジェクト設定 > 全般 から取得した設定値を以下に記載してください
# このファイルは公開リポジトリにコミット可能です（実際の値は含めない）

# Firebase API Key
FIREBASE_API_KEY=your-firebase-api-key-here

# Firebase Auth Domain
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# Firebase Project ID
FIREBASE_PROJECT_ID=your-project-id

# Firebase Storage Bucket
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# Firebase Messaging Sender ID
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id

# Firebase App ID
FIREBASE_APP_ID=your-app-id

# AdMob Configuration (Optional)
# ADMOB_APP_ID=your-admob-app-id
# ADMOB_BANNER_ID=your-banner-id
# ADMOB_INTERSTITIAL_ID=your-interstitial-id

# Google Maps API Keys
# Google Cloud Console > APIs & Services > Credentials から取得
# iOS用とAndroid用で異なるAPIキーを設定可能（または同じキーを使用）
GOOGLE_MAPS_API_KEY_IOS=your-google-maps-api-key-for-ios
GOOGLE_MAPS_API_KEY_ANDROID=your-google-maps-api-key-for-android

# Facebook SDK Configuration (react-native-fbsdk-next)
# Meta for Developers > アプリ設定 から取得
# app.config.js で react-native-fbsdk-next プラグインを有効化するために必要
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_CLIENT_TOKEN=your-facebook-client-token
